# Provide at least one API key. memlab auto-registers a connector for each
# vendor key it finds. The primary connector is the first detected in this
# priority order: OpenAI > Anthropic > Google > Groq > DeepSeek > Mistral >
# Together > Grok > Perplexity > Ollama. Override with MEMLAB_PRIMARY.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=

# Optional overrides
# MEMLAB_PRIMARY=openai           # connector name to use as primary
# MEMLAB_CHAT_MODEL=gpt-5         # override chat model
# MEMLAB_EXTRACT_MODEL=gpt-5-mini # override extraction model
# MEMLAB_PROFILE_MODEL=gpt-5-mini # override profile-generation model
# MEMLAB_USER_ID=user-1
# MEMLAB_AGENT_ID=agent-1
